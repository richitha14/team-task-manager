# ─── Railway production variables (set in Railway → Service → Variables) ─────
# Do NOT commit real secrets. Link PostgreSQL plugin first — Railway injects DATABASE_URL.

NODE_ENV=production
PORT=3001

# Injected by Railway PostgreSQL plugin:
# DATABASE_URL=postgresql://...

# Your public app URL (use Railway variable reference):
# CORS_ORIGIN=https://${{RAILWAY_PUBLIC_DOMAIN}}
CORS_ORIGIN=https://your-app.up.railway.app

# Generate: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Single-service deploy: API serves React build (default when NODE_ENV=production)
SERVE_CLIENT=true

# Leave empty — frontend calls /api on same origin
# VITE_API_URL=

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# ─── Optional: two-service deploy (API + static frontend separately) ─────────
# Backend service only:
#   SERVE_CLIENT=false
#   CORS_ORIGIN=https://your-frontend.up.railway.app
# Frontend service build env:
#   VITE_API_URL=https://your-api.up.railway.app
#   Build: npm run build -w client
#   Start: npx serve -s client/dist -l $PORT
