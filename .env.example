# ─── Root / shared defaults (copy to .env) ───────────────────────────────────

# PostgreSQL connection (used by Prisma in server/)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/team_task_manager?schema=public"

# API (server/)
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Frontend (client/) — Vite exposes only VITE_* vars
# Dev: point to API. Production (Railway single-service): leave empty for same-origin /api
VITE_API_URL=http://localhost:3001

# Production single-service deploy (see .env.railway.example)
# SERVE_CLIENT=true
